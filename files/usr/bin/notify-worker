#!/bin/sh

umask 077
PATH=/usr/sbin:/usr/bin:/sbin:/bin
export PATH
LC_ALL=C
export LC_ALL

TAG=notify-worker
LOCK_DIR=/tmp/notify-worker.lock

log() { logger -t "$TAG" -- "$*"; }
cfg() { uci -q get "notify.main.$1" 2>/dev/null || printf '%s' "$2"; }
cleanup() { rm -rf "$LOCK_DIR"; [ -n "$response_file" ] && rm -f "$response_file"; log "worker stopped"; }

if ! mkdir "$LOCK_DIR" 2>/dev/null; then
	old_pid=$(cat "$LOCK_DIR/pid" 2>/dev/null)
	case "$old_pid" in ''|*[!0-9]*) old_pid='' ;; esac
	if [ -n "$old_pid" ] && kill -0 "$old_pid" 2>/dev/null; then
		log "another worker is already running"
		exit 1
	fi
	rm -rf "$LOCK_DIR"
	mkdir "$LOCK_DIR" 2>/dev/null || { log "cannot acquire worker lock"; exit 1; }
fi
printf '%s\n' "$$" > "$LOCK_DIR/pid"
response_file=''
trap cleanup EXIT
trap 'exit 0' HUP INT TERM

enabled=$(cfg enabled 1)
[ "$enabled" = 1 ] || { log "worker disabled by configuration"; exit 0; }
token=$(cfg token '')
chat_id=$(cfg chat_id '')
[ -n "$token" ] && [ -n "$chat_id" ] || { log "configuration error: token or chat_id is missing"; exit 1; }
case "$token:$chat_id" in *PUT_TELEGRAM*|*PUT_CHAT_ID*) log "configuration error: Telegram credentials are not configured"; exit 1 ;; esac
queue_dir=$(cfg queue_dir /overlay/notify-queue)
idle_interval=$(cfg idle_interval 15)
retry_interval=$(cfg retry_interval 15)
max_attempts=$(cfg max_attempts 20)
connect_timeout=$(cfg connect_timeout 10)
request_timeout=$(cfg request_timeout 30)
valid_uint() { case "$2" in ''|*[!0-9]*) log "configuration error: invalid numeric option $1"; exit 1 ;; esac; }
valid_uint idle_interval "$idle_interval"
valid_uint retry_interval "$retry_interval"
valid_uint max_attempts "$max_attempts"
valid_uint connect_timeout "$connect_timeout"
valid_uint request_timeout "$request_timeout"
[ "$max_attempts" -gt 0 ] || { log "configuration error: max_attempts must be positive"; exit 1; }
[ "$idle_interval" -gt 0 ] && [ "$retry_interval" -gt 0 ] || { log "configuration error: intervals must be positive"; exit 1; }
for dir in "$queue_dir/tmp" "$queue_dir/new" "$queue_dir/failed"; do mkdir -p "$dir" || exit 1; done

log "worker started"
while :; do
	file=$(find "$queue_dir/new" -type f -name '*.msg' 2>/dev/null | sort | head -n 1)
	if [ -z "$file" ]; then sleep "$idle_interval"; continue; fi
	[ -f "$file" ] && [ ! -L "$file" ] || { log "unsafe or unreadable queue entry ignored"; sleep "$idle_interval"; continue; }

	timestamp=$(sed -n 's/^timestamp=//p' "$file" | head -n 1)
	hostname_value=$(sed -n 's/^hostname=//p' "$file" | head -n 1)
	level=$(sed -n 's/^level=//p' "$file" | head -n 1)
	attempts=$(sed -n 's/^attempts=//p' "$file" | head -n 1)
	case "$attempts" in ''|*[!0-9]*) log "invalid queue file moved to failed"; mv "$file" "$queue_dir/failed/"; continue ;; esac
	case "$level" in info|warning|error|critical) : ;; *) log "invalid queue file moved to failed"; mv "$file" "$queue_dir/failed/"; continue ;; esac
	body=$(sed '1,/^$/d' "$file")
	[ -n "$timestamp" ] && [ -n "$hostname_value" ] && [ -n "$body" ] || { log "invalid queue file moved to failed"; mv "$file" "$queue_dir/failed/"; continue; }
	display_time=$(printf '%s' "$timestamp" | sed 's/T/ /; s/[+-][0-9][0-9][0-9][0-9]$//')
	text=$(printf '%s\n%s\n%s\n\n%s' "$hostname_value" "$display_time" "$(printf '%s' "$level" | tr 'a-z' 'A-Z')" "$body")
	response_file="/tmp/notify-response.$$"
	: > "$response_file"
	http_code=$(curl -sS --connect-timeout "$connect_timeout" --max-time "$request_timeout" \
		-o "$response_file" -w '%{http_code}' -X POST \
		--data-urlencode "chat_id=$chat_id" --data-urlencode "text=$text" \
		"https://api.telegram.org/bot${token}/sendMessage")
	curl_status=$?
	ok=false
	if command -v jsonfilter >/dev/null 2>&1; then
		[ "$(jsonfilter -i "$response_file" -e '@.ok' 2>/dev/null)" = true ] && ok=true
	else
		grep -Eq '"ok"[[:space:]]*:[[:space:]]*true' "$response_file" && ok=true
	fi
	if [ "$curl_status" -eq 0 ] && [ "$http_code" = 200 ] && [ "$ok" = true ]; then
		rm -f "$file"
		log "notification sent (file=${file##*/})"
		rm -f "$response_file"; response_file=''
		continue
	fi

	attempts=$((attempts + 1))
	if [ "$attempts" -ge "$max_attempts" ]; then
		mv "$file" "$queue_dir/failed/"
		log "maximum attempts reached; notification moved to failed (http=$http_code)"
		rm -f "$response_file"; response_file=''
		continue
	fi
	updated="$queue_dir/tmp/.retry.$$"
	sed "s/^attempts=.*/attempts=$attempts/" "$file" > "$updated" && mv "$updated" "$file"
	exponent=$((attempts - 1))
	[ "$exponent" -le 5 ] || exponent=5
	delay=$((retry_interval * (1 << exponent)))
	[ "$delay" -le 300 ] || delay=300
	if [ "$http_code" = 429 ]; then
		if command -v jsonfilter >/dev/null 2>&1; then retry_after=$(jsonfilter -i "$response_file" -e '@.parameters.retry_after' 2>/dev/null); else retry_after=''; fi
		case "$retry_after" in ''|*[!0-9]*) : ;; *) [ "$retry_after" -gt "$delay" ] && delay=$retry_after ;; esac
	fi
	log "send failed; retry scheduled (attempt=$attempts, http=$http_code, curl=$curl_status, delay=${delay}s)"
	rm -f "$response_file"; response_file=''
	sleep "$delay"
done
